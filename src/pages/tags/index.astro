---
import Base from "../../layouts/Base.astro";
import { getPublishedPosts, groupByTag, slugify } from "../../lib/content";

const tags = groupByTag(await getPublishedPosts());
---

<Base title="Tags">
  <h1>Tags</h1>
  {
    tags.length ? (
      <ul class="index-list">
        {tags.map(([tag, posts]) => (
          <li>
            <a href={`/tags/${slugify(tag)}/`}>{tag}</a>
            <span class="meta"> {posts.length}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">No tagged writing yet.</p>
    )
  }
</Base>
