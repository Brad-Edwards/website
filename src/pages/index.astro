---
import Base from "../layouts/Base.astro";

import { formatDate, getPublishedPosts } from "../lib/content";

const recentPosts = (await getPublishedPosts()).slice(0, 5);
const projects = [
  {
    title: "APTL",
    href: "https://github.com/Brad-Edwards/aptl",
    summary: "Advanced Purple Team Lab for AI-driven purple-team scenarios.",
  },
  {
    title: "Shifter",
    href: "https://github.com/PaloAltoNetworks/shifter",
    summary: "Self-service agentic cyber range platform at Palo Alto Networks.",
  },
  {
    title: "ACES",
    href: "https://github.com/Brad-Edwards/aces",
    summary: "Scenario description language and reference runtime for cyber range experiments.",
  },
];
---

<Base home>
  <section class="intro" aria-labelledby="intro-title">
    <h1 id="intro-title">Brad Edwards</h1>
    <p class="role">Applied security research - agentic systems, cyber ranges, SOC tooling.</p>
    <p class="lede">
      I work on agentic systems for security operations: open-source tooling for
      purple-team automation, formalizing cyber range design, and AI-assisted
      development pipelines for security software. Day job is SecOps domain
      consultant at Palo Alto Networks. Prior life in law enforcement digital
      forensics, backend engineering, and secops leadership. Based in BC.
    </p>
  </section>

  <section id="projects" aria-labelledby="projects-title">
    <h2 id="projects-title">Projects</h2>
    <ul class="project-list">
      {
        projects.map((project) => (
          <li>
            <a href={project.href}>{project.title}</a>
            <p>{project.summary}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section aria-labelledby="recent-writing-title">
    <h2 id="recent-writing-title">Recent writing</h2>
    {
      recentPosts.length ? (
        <ol class="entries">
          {recentPosts.map((post) => (
            <li>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              <p class="meta">
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              </p>
              {post.data.description && <p>{post.data.description}</p>}
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty">No published posts yet.</p>
      )
    }
    <p><a href="/posts/">All posts</a></p>
  </section>

  <section id="talks" aria-labelledby="talks-title">
    <h2 id="talks-title">Talks &amp; appearances</h2>
    <p class="empty">Talks and appearances will be listed here.</p>
  </section>
</Base>
